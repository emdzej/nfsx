{
  "name": "@emdzej/nfsx-runtime",
  "version": "0.5.0",
  "description": "CABI-style IPO runtime for nfsx. Wraps the inpax VM with the NCSEXPER 99-slot CABI surface (via @emdzej/ncsx-inpax-cabi-provider) plus NFS-specific overrides for flash/FSC/AIF slots not in the NCSEXPER table.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@emdzej/inpax-parser": "^0.7.1",
    "@emdzej/inpax-interpreter": "^0.7.1",
    "@emdzej/inpax-core": "^0.7.1",
    "@emdzej/inpax-providers": "^0.7.1",
    "@emdzej/inpax-mock-provider": "^0.7.1",
    "@emdzej/inpax-interfaces": "^0.7.1",
    "@emdzej/ncsx-inpax-cabi-provider": "^0.4.0",
    "@emdzej/ncsx-chassis": "^0.4.0",
    "@emdzej/ncsx-fa-asw": "^0.4.0",
    "@emdzej/ncsx-wire": "^0.4.0",
    "@emdzej/bimmerz-logger": "^0.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/nfsx.git",
    "directory": "packages/runtime"
  }
}
