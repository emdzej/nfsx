{
  "name": "@emdzej/nfsx-cli",
  "version": "0.4.0",
  "description": "BMW NFS / WinKFP reconstruction CLI — `nfsx plan` resolves a part number through SP-Daten and prints the flash context (IPO + SGBD + working files + transport).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "nfsx": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "nfsx": "node dist/cli.js"
  },
  "dependencies": {
    "@emdzej/nfsx-resolver": "workspace:*",
    "@emdzej/nfsx-data-files": "workspace:*",
    "@emdzej/nfsx-runtime": "workspace:*",
    "@emdzej/nfsx-flash": "workspace:*",
    "@emdzej/nfsx-flash-data": "workspace:*",
    "@emdzej/nfsx-bootmode": "workspace:*",
    "@emdzej/nfsx-directmode": "workspace:*",
    "@emdzej/nfsx-ms45": "workspace:*",
    "@emdzej/inpax-mock-provider": "^0.12.0",
    "@emdzej/inpax-interfaces": "^0.12.0",
    "@emdzej/inpax-ediabasx-provider": "^0.12.0",
    "@emdzej/ediabasx-client": "^0.8.0",
    "@emdzej/ediabasx-core": "^0.8.0",
    "@emdzej/ediabasx-ediabas": "^0.8.0",
    "@emdzej/ediabasx-host-config": "^0.8.0",
    "@emdzej/ediabasx-interface-base": "^0.8.0",
    "@emdzej/ediabasx-interfaces": "^0.8.0",
    "@emdzej/ediabasx-interface-serial": "^0.8.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "ink": "^5.1.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emdzej/nfsx.git",
    "directory": "apps/cli"
  }
}
